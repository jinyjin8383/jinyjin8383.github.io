
function getFormattedDate(args= '', separator= '-') {
  let strDate = '';
  if(isNotEmpty(args)) {
    const tempDate = args.toString().replace(/[^0-9]/g, '');
    if(tempDate.length === 8) {
      strDate = tempDate.substring(0, 4) + separator + tempDate.substring(4, 6) + separator + tempDate.substring(6, 8);
    }
  }
  return strDate;
}

function getFormattedRangeDate(args1= '', args2= '', separator= '-') {
  let strDate = '';
  let endDate = '';
  let Dates = [];
  if(isNotEmpty(args1)) {
    const tempDate = args1.toString().replace(/[^0-9]/g, '');
    if(tempDate.length === 8) {
      strDate = tempDate.substring(0, 4) + separator + tempDate.substring(4, 6) + separator + tempDate.substring(6, 8);
    }
  }
  if(isNotEmpty(args2)) {
    const tempDate2 = args2.toString().replace(/[^0-9]/g, '');
    if(tempDate2.length === 8) {
      endDate = tempDate2.substring(0, 4) + separator + tempDate2.substring(4, 6) + separator + tempDate2.substring(6, 8);
    }
  }
  Dates[0] = strDate;
  Dates[1] = endDate;
  return Dates;
}

function getFormattedTime(args= '', separator= ':') {
  let strTime = '';
  if(isNotEmpty(args)) {
    const tempTime = args.toString().replace(/[^0-9]/g, '');
    if(tempTime.length === 4) {
      const hh = tempTime.substring(0, 2);
      const mm = tempTime.substring(2, 4);
      strTime = hh + separator + mm;
    }
  }
  return strTime;
}

function isValidTime(args= '') {
  let rtnValue = false;
  if(isNotEmpty(args)) {
    const tempTime = args.toString().replace(/[^0-9]/g, '');
    if(tempTime.length === 4) {
      const hh = tempTime.substring(0, 2);
      const mm = tempTime.substring(2, 4);
      if(Number(hh) >= 0 && Number(hh) < 24 && Number(mm) >= 0 && Number(mm) < 60) {
        rtnValue = true;
      }
    }
  }
  return rtnValue;
}

function isValidDate(args= '') {
  try {
    const tempDate = args.replace(/[^0-9]/g, '');
    if(tempDate.length !== 8) {
      return false;
    }

    const year = Number(tempDate.substring(0, 4));
    const month = Number(tempDate.substring(4, 6));
    const day = Number(tempDate.substring(6, 8));

    if(month < 1 || month > 12) {
      return false;
    }

    const maxDaysInMonth = [31, 28, 31, 30, 31, 30, 31, 31, 30, 31, 30, 31];
    let maxDay = maxDaysInMonth[month-1];

    // 윤년 체크
    if( month === 2 && ( (year%4 === 0 && year%100 !== 0) || year%400 === 0 ) ) {
      maxDay = 29;
    }

    if(day <= 0 || day > maxDay) {
      return false;
    }

    return true;

  } catch (err) {
    return false;
  }
}