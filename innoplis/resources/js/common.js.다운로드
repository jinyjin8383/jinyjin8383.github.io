function fnGetFormattedDate() {
  const args = arguments[0];
  const separator = arguments[1] ?? '-';
  let strDate = '';
  if(isNotEmpty(args)) {
    const tempDate = args.toString().replace(/[^0-9]/g, '');
    if(tempDate.length === 8) {
      strDate = tempDate.substring(0, 4) + separator + tempDate.substring(4, 6) + separator + tempDate.substring(6, 8);
    } else if(tempDate.length === 6) {
      strDate = tempDate.substring(0, 4) + separator + tempDate.substring(4, 6);
    } else {
      strDate = tempDate;
    }
  }
  return strDate;
}

function fnFormValidation() {
  let rtnVal = true;
  const formId = arguments[0];
  const schema = arguments[1];

  if(rtnVal) {
    Object.getOwnPropertyNames(schema).forEach(element1 => {
      [...document.querySelectorAll(`#${formId} input, textarea, select`)]
      .filter(f => f.name === element1)
      .map(element2 => {
        const title = schema[element1]?.title;
        const required = schema[element1]?.required;
        const minLength = schema[element1]?.minLength;
        const maxLength = schema[element1]?.maxLength;
        const isNumber = schema[element1]?.isNumber;
        const pattern = schema[element1]?.pattern;
        let value;

        if(element2.type === 'radio') {
          value = document.querySelector(`input[name^="${element1}"]:checked`)?.value;
        } else if(element2.type === 'select-one') {
          const sel = document.getElementById(element1);
          value = sel.options[sel.selectedIndex].value;
        } else if(element2.type === 'checkbox') {
          value = document.querySelector(`input[name^="${element1}"]:checked`);
        } else {
          value = element2.value;
        }

        // 필수값 확인
        if(rtnVal && required && isEmpty(value)) {
          const msg = `${title} 는(은) 필수 입니다.`;

          fnValidaionTargetFocus(element1,element2.type);

          toastr.warning(msg);
          rtnVal = false;
        }

        // 최소 길이 확인
        if(rtnVal && isNotEmpty(minLength) && isNotEmpty(value)) {
          if(value.length < minLength) {
            const msg = `${title} 의 최소 길이는 ${minLength} 입니다.`;

            fnValidaionTargetFocus(element1,element2.type);

            toastr.warning(msg);
            rtnVal = false;
          }
        }

        // 최대 길이 확인
        if(rtnVal && isNotEmpty(maxLength) && isNotEmpty(value)) {
          if(value.length > maxLength) {
            const msg = `${title} 의 최대 길이는 ${maxLength} 입니다.`;

            fnValidaionTargetFocus(element1,element2.type);

            toastr.warning(msg);
            rtnVal = false;
          }
        }

        // 숫자만 입력
        if(rtnVal && isNumber && isNotEmpty(value)) {
          const regexp = /^[0-9]*$/;
          if(!regexp.test(value)) {
            const msg = `${title} 는(은) 숫자만 입력 가능 합니다.`;

            fnValidaionTargetFocus(element1,element2.type);

            toastr.warning(msg);
            rtnVal = false;
          }
        }

        // 패턴 확인
        if(rtnVal && pattern && isNotEmpty(value)) {
          if(!pattern['regexp'].test(value)) {
            const patternMsg = pattern['patternMsg'];
            const msg = `${title} 는(은) ${patternMsg} 형식으로 입력해야 합니다.`;

            fnValidaionTargetFocus(element1,element2.type);

            toastr.warning(msg);
            rtnVal = false;
          }
        }

        if(!rtnVal) return;
      });
    });


  } else if(!rtnVal) {
    return;
  }

  return rtnVal;
}

function fnValidaionTargetFocus(el, eltype){
  // console.log(eltype);
  if(el){
    if(eltype == 'textarea'){
        setTimeout(function(){
          document.querySelector(`${eltype}[name=${el}]`).focus();
        }, 1)

        document.querySelector(`${eltype}[name=${el}]`).classList.add("org-background");
        document.querySelector(`${eltype}[name=${el}]`).addEventListener("focusout",
          function(){document.querySelector(`${eltype}[name=${el}]`).classList.remove('org-background')}
        );
    }
    else{
      setTimeout(function(){
        document.querySelector(`input[name=${el}]`).focus();
      }, 1)

      document.querySelector(`input[name=${el}]`).classList.add("org-background");
      document.querySelector(`input[name=${el}]`).addEventListener("focusout",
        function(){document.querySelector(`input[name=${el}]`).classList.remove('org-background')}
      );
    }
  }
}

