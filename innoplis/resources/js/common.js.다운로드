    if(status !== 'C') {
      delRow.querySelector('input[name=DATA_STATUS]').value = 'D';
      delArr.push(fnGetRowObj(delRow));
    }
  });
}

function fnGetSaveList() {
  const bodyId = arguments[0];
  let objArr = new Array();

  [...document.querySelectorAll(`#${bodyId} tr`)]
  .filter(f => f.className != 'hidden')
  .map(tr => {
    let obj = new Object();
    [...tr.querySelectorAll('td')]
    .filter(f => f.querySelector('input, textarea, select'))
    .map(td => {
      if(isNotEmpty(td.querySelector('input'))) {
        const input = td.querySelector('input');
        const inputCol = input.dataset.col;

        if(input.type === 'radio') {
          obj[inputCol] = tr.querySelector(`input[name^="${input.name}"]:checked`)?.value;
        } else if(input.type === 'checkbox') {
          const chkArr = [];
