function fnInitData() {

  const httpRequest = arguments[0];
  const obj = httpRequest.response;
  const formId = arguments[1];

  if(obj) {
    Object.keys(obj).forEach(k => {
      [...document.getElementById(formId).elements]
      .filter(f => f.name === k)
      .map( m => {
        const isDatePicker = m?.classList?.contains('datepicker-input');
        if(isDatePicker) {
          if(m.name === k) {
            m.value = fnGetFormattedDate(obj[k], '-');
          }
        } else if(m.nodeName === 'INPUT' && m.type === 'text') {
          if(m.name === k) {
            m.value = obj[k];
          }
        } else if(m.nodeName === 'INPUT' && (m.type === 'radio' || m.type === 'checkbox')) {
          if(m.name === k) {
            if(m.value === obj[k]) {
              m.checked = true;
            }
          }
        } else if(m.nodeName === 'INPUT' && m.type === 'date') {
          if(m.name === k) {
            m.value = obj[k];
          }
        } else if(m.nodeName === 'INPUT' && m.type === 'hidden') {
          if(m.name === k) {
            m.value = obj[k];
          }
        } else if(m.nodeName === 'SELECT' && m.type === 'select-one') {
          if(m.name === k) {
            m.value = obj[k];
            
            if(obj[k] == null || obj[k] == ""){
              m.options[0].selected = true;
            }else{
              for(let i=0; i <m.options.length; i++){
                if(m.options[i].value == obj[k]){
                  m.options[i].selected = true;
                }
              }
            } 
          }
        } else if(m.nodeName === 'TEXTAREA'  && m.type === 'textarea') {
          if(m.name === k) {
            m.value = obj[k];
          }
        }
      });
    })
  }
}

