function fnParseJavaObj() {
  var obj = arguments[0];

  var str = obj.split('(').pop().split(')').join('');
  var props = str.split(', ');
  var parsedData = {};
  for(var j = 0; props.length > j; j++) {
    var prop = props[j];
    prop = prop.trim();
    var key = prop.substring(0, prop.indexOf("="));
    var val = prop.substring(prop.indexOf("=") +1);
    if(val == 'null') val = null;
    parsedData[key] = val;
  }
  return parsedData;
}

function fnParseJavaObjList() {
  var obj = arguments[0];
  var resultJson = [];

  var str = obj.split('[{').join('').split('}]').join('');
  var rows = str.split('}, {');
  for(var i = 0; rows.length > i; i++) {
    var cols = rows[i].split(', ');
    var rowData = {};
    for(var j = 0; cols.length > j; j++) {
      var colData = cols[j];
      colData = colData.trim();
      var key = colData.substring(0, colData.indexOf("="));
      var val = colData.substring(colData.indexOf("=") +1);
      rowData[key] = val;
    }
    resultJson.push(rowData);
  }
  return resultJson;
}

function fnParseJavaStrList() {
  var obj = arguments[0];
