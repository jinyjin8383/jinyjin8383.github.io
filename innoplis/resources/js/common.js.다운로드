function isObjectType(args) {
  return Object.prototype.toString.call(args).slice(8, -1);
}

function isEmpty(args) {
  let result = false;
  const type = isObjectType(args);

  if(type === 'String') { // String
    if(args === '' || args === "") result = true;
  } else if(type === 'Number') { // Number
    result = false;
  } else if(type === 'Boolean') { // Boolean
    result = false;
  } else if(type === 'Object') { // Object
    if(Object.keys(args).length === 0) result = true;
  } else if(type === 'Array') { // Array
    if(args.length === 0) result = true;
  } else if(type === 'RegExp') { // RegExp
    result = false;
  } else if(type === 'Math') { // Math
    result = false;
  } else if(type === 'Date') { // Date
    result = false;
  } else if(type === 'Function') { // Function
    result = false;
  } else if(type === 'File') { // File
    result = false;
  } else if(type === 'Undefined') { // Undefined
    result = true;
  } else if(type === 'Null') { // Null
    result = true;
  }

  return result;
}

function isNotEmpty(args) {
  let result = true;
  if(isEmpty(args)) {
    result = false;
  }
  return result;
}

function replaceAll(str, from, to) {
  const regExp = new RegExp(from, 'g');
  return str.replace(regExp, to);
}

function addComma(args) {
  let result = '';
  if(isNotEmpty(args)) {
    const tempArgs = args.toString().replace(/[^0-9]/g, '');

    if(isNotEmpty(tempArgs)) {
      let str = removeComma(args.toString());
      let x = str.split('.');

      let x1 = x[0];
      let x2 = x.length > 1 ? '.' + x[1] : '';
      var regex = /(\d+)(\d{3})/;


      while(regex.test(x1)) {
        x1 = x1.replace(regex, '$1' + ',' + '$2');
      }
      result = x1 + x2;
    }
  }
  return result;
}

function removeComma(args) {
  const regex = /,/g;
  return args.replace(regex, '');
}

function fnOpenWindowPopup(args) {

  let url = environment.apiUrl + args.url;
  const target = args.target ?? 'winPopup1';
  const width = args.width ?? 400;
  const height = args.height ?? 400;
  const param = args.param ?? {};

  const scrollbarsOption = args.scrollbarsOption ?? false;
  const resizableOption = args.resizableOption ?? true;
  const restOption = args.restOption ?? false;

  let left = (screen.availWidth-width) / 2;
  if(window.screenLeft < 0) {
    left += window.screen.width * -1;
  } else if(window.screenLeft > window.screen.width) {
    left += window.screen.width;
  }
  const top = (screen.availHeight - height) / 2 - 10;

  let openStr  = 'width=' + width;
  openStr += ', height=' + height;
  openStr += ', left=' + left;
  openStr += ', top=' + top;

  if(scrollbarsOption) {
    openStr += ', scrollbars=yes';
  } else {
    openStr += ', scrollbars=no';
  }

  if(resizableOption) {
    openStr += ', resizable=yes';
  } else {
    openStr += ', resizable=no';
  }

  if(restOption) {
    openStr += ',toolbar=yes, menubar=yes, location=yes, status=yes';
  }

  if(isNotEmpty(param)) {
    let cnt = 0;
    if(url.indexOf('?') > -1) {
      cnt++;
    }
    Object.keys(param).forEach(k => {
      if(isNotEmpty(param[k])) {
        if(cnt === 0) {
          url += '?';
        } else {
          url += '&';
        }
        url += k;
        url += '=';
        url += param[k];
        cnt++;
      }
    });
  }

  const popup = window.open(encodeURI(url), target, openStr);
  if(popup) popup?.focus();

  return popup;
}

function fnEscapeReplace(value) {
  if(isNotEmpty(value)) {
    value = replaceAll(value, '&#60;', '<');
    value = replaceAll(value, '&#62;', '>');
    value = replaceAll(value, '&#40;', '(');
    value = replaceAll(value, '&#41;', ')');
    value = replaceAll(value, '&#91;', '[');
    value = replaceAll(value, '&#93;', ']');
    value = replaceAll(value, '&#47;', '/');
    value = replaceAll(value, '&#36;', '$');
    value = replaceAll(value, '&#34;', '"');
    value = replaceAll(value, '&#39;', '\'');
  }
  return value;
}

function fnSetPageInfo() {

  var args_page = arguments[0];
  var args_listTotalCnt = arguments[1];
  var args_listSize = isEmpty(arguments[2]) ? 10 : arguments[2];
  var callback = isEmpty(arguments[3]) ? 'fnSearch' : arguments[3];
  var target = isEmpty(arguments[4]) ? 'pagination' : arguments[4];

  var listSize = args_listSize; // 한페이지당 게시물 수
  var rangeSize = 10; // 페이징 범위
  var page = 1;
  var range = 0;
  var rangePrev = null;
  var rangeNext = null;
  var listTotalCnt = null;
  var pageCnt = null;
  var startPage = null;
  var startIndex = null;
  var endIndex = null;
  var endPage = 0;
  var prev = null;
  var next = true;

  page = args_page;
  range = args_page%10 === 0 ? (args_page - (rangeSize - 1)) : (Math.floor(args_page / 10) * 10) + 1;
  rangePrev = range - listSize;
  rangeNext = range + listSize;
  listTotalCnt = args_listTotalCnt;

  // 전체 페이지수
  pageCnt = Math.ceil(listTotalCnt/listSize);

  // 시작 페이지
  startPage = (range - 1) * rangeSize + 1 ;

  // 끝 페이지
  // endPage = range * rangeSize;
  endPage = range + rangeSize - 1;

  // 게시판 시작번호
  startIndex = ((page - 1) * listSize) + 1;
  // 게시판 끝번호
  endIndex = startIndex + listSize - 1;

  // 이전 버튼 상태
  prev = range === 1 ? false : true;

  // 다음버튼 상태
  next = endPage >= pageCnt ? false : true;
  if(endPage > pageCnt) {
    endPage = pageCnt;
    next = false;
  }
  // if(next) {
  //   endPage = pageCnt;
  //   next = false;
  // }

  var html = ``;

  html += `<input type="hidden" id="PAGE" name="PAGE" value="${page}">`;
  html += `<input type="hidden" id="CNT_PER_PAGE" name="CNT_PER_PAGE" value="${listSize}">`;
  html += `<input type="hidden" id="START_INDEX" name="START_INDEX" value="">`;
  html += `<input type="hidden" id="END_INDEX" name="END_INDEX" value="">`;

  if(listTotalCnt === 0) {
    html += `<li class="page-item active"><a class="page-link" href="javascript:fnSearch();">1</a></li>`;
  } else {
    html += `<li class="page-item arr">`;
    // html += `<a class="page-link" href="javascript:` + callback +`(` + 1 + `);" aria-label="Previous">`;
    html += `<a class="page-link" href="javascript:fnMovePage(1, ${callback}, '${target}');" aria-label="Previous">`;
    html += `<span class="visually-hidden">처음으로</span><span aria-hidden="true"><i class="las la-angle-double-left"></i></span>`;
    html += `</a>`;
    html += `</li>`;

    if(prev) {
      html += `<li class="page-item arr">`;
      // html += `<a class="page-link" href="javascript:` + callback +`(` + rangePrev + `);" aria-label="PreviousEnd">`;
      html += `<a class="page-link" href="javascript:fnMovePage(${rangePrev}, ${callback}, '${target}');" aria-label="PreviousEnd">`;
      html += `<span class="visually-hidden">이전으로</span><span aria-hidden="true"><i class="las la-angle-left"></i></span>`;
      html += `</a>`;
      html += `</li>`;
    }

    for(var i=0; i<listSize; i++) {
      if(i+range <= endPage) {
        if(page == (i+range)) {
          html += `<li class="page-item active">`;
        } else {
          html += `<li class="page-item">`;
        }
        // html += `<a class="page-link" href="javascript: ` + callback +`(` + (i+range)  + `);">`;
        html += `<a class="page-link" href="javascript:fnMovePage(${i+range}, ${callback}, '${target}');">`;
        html += (i+range);
        html += `</a>`;
        html += `</li>`;
      }
    }

    if(next) {
      html += `<li class="page-item arr">`;
      // html += `<a class="page-link" href="javascript:` + callback +`(` + rangeNext + `);" aria-label="Next">`;
      html += `<a class="page-link" href="javascript:fnMovePage(${rangeNext}, ${callback}, '${target}');" aria-label="Next">`;
      html += `<span class="visually-hidden">마지막으로</span><span aria-hidden="true"><i class="las la-angle-right"></i></span>`;
      html += `</a>`;
      html += `</li>`;
    }

    html += `<li class="page-item arr">`;
    // html += `<a class="page-link" href="javascript:` + callback +`(` + pageCnt + `);" aria-label="NextEnd">`;
    html += `<a class="page-link" href="javascript:fnMovePage(${pageCnt}, ${callback}, '${target}');" aria-label="NextEnd">`;
    html += `<span class="visually-hidden">다음으로</span><span aria-hidden="true"><i class="las la-angle-double-right"></i></span>`;
    html += `</a>`;
    html += `</li>`;

  }

  document.querySelector('.' + target).innerHTML = html;

  return page;
}

function fnMovePage() {
  var page = arguments[0];
  var callback = isEmpty(arguments[1]) ? 'fnSearch' : arguments[1];
  var target = isEmpty(arguments[2]) ? 'pagination' : arguments[2];

  const targetElm = document.querySelector(`.${target}`);
  const listSizeElm = targetElm.querySelector('#CNT_PER_PAGE');

  var listSize = isEmpty(listSizeElm) ? 10 : +listSizeElm.value;
  var startIndex = ((page - 1) * listSize) + 1;
  var endIndex = startIndex + listSize - 1;

  targetElm.querySelector('#PAGE').value = page;
  targetElm.querySelector('#START_INDEX').value = startIndex;
  targetElm.querySelector('#END_INDEX').value = endIndex;

  if(isNotEmpty(callback)) callback(page);
}

function fnDrawCode() {

  const httpRequest = arguments[0];
  const option = arguments[1];
  const response = httpRequest.response;

  Object.keys(option).forEach((k,v) => {
    const type = option[k].type;
    const column = option[k].column;
    const target = option[k].target;
    const selectValue = option[k]?.selectValue ?? [];
    const firstCode = option[k]?.firstCode ?? [];
    const title = option[k]?.title ?? '';
    const changeCallback = option[k]?.changeCallback ?? [];
    const readonly = option[k]?.readonly ?? [];

    const data = response[k];
    for(let i=0; i<target.length; i++) {
      const t = document.getElementById(target[i]);
      let html = ``;
      const disabled = readonly[i] ? 'disabled' : '';
      if(type[i] === 'select') {
        if(arguments[2] != undefined){
          html += '<i class="las la-building "></i>';
          html += '<label class="visually-hidden" for="ENPR_SHPE_CD">기업형태</label>';
        }

        if(isEmpty(changeCallback)) {
          html += `<select class="form-select grid-input" id="` + column[i] + `" name="` + column[i] + `" data-col="` + column[i]  + `" title="` + title[i] + `" ${disabled}>`;
        } else {
          html += `<select class="form-select grid-input" id="` + column[i] + `" name="` + column[i] + `" data-col="` + column[i]  +  `" title="` + title[i] + `" onchange="` + changeCallback[i] + `(this);" ${disabled}>`;
        }
        if(isNotEmpty(firstCode[i])) {
          html += `<option value="">` + firstCode[i] + `</option>`;
        }
        for(let j=0; j<data.length; j++) {
          let selected = '';
          if(isEmpty(selectValue) && j===0) selected = 'selected';
          else if(isNotEmpty(selectValue)) selected = data[j].DATA === selectValue[i] ? 'selected' : '';
          html += `<option value="` + data[j].DATA + `" ` + selected + `>` + data[j].LABEL + `</option>`;
        }
        html += `</select>`;
      } else if(type[i] === 'radio' || type[i] === 'checkbox') {
        if(type[i] === 'radio' && isNotEmpty(firstCode[i])) {
          html += `<div class="form-check">`;
          if(isEmpty(changeCallback)) {
            html += `<input type="radio" id="` + (column[i] + `_0`) + `" name="` + column[i] + `" data-col="` + column[i] + `" class="form-check-input" value="" title="` + firstCode[i] + `" ${disabled}>`;
          } else {
            html += `<input type="radio" id="` + (column[i] + `_0`) + `" name="` + column[i] + `" data-col="` + column[i] + `" class="form-check-input" value="" title="` + firstCode[i] + `" onchange="` + changeCallback[i] + `(this);" ${disabled}>`;
          }
          html += `<label for="` + (column[i] + `_0`) + `" class="form-check-label"><span class="radio"></span>` + firstCode[i] + `</label>`;
          html += `</div>`;
        }
        for(let j=0; j<data.length; j++) {
          const id = ( column[i] + `_` + (j+1) );
          let checked = '';
          if(isEmpty(selectValue) && j===0) checked = 'checked';
          else if(isNotEmpty(selectValue)) checked = data[j].DATA === selectValue[i] ? 'checked' : '';
          html += `<div class="form-check">`;
          if(isEmpty(changeCallback)) {
            html += `<input type="` + type[i] + `" id="` + id  + `" name="` + column[i] + `" data-col="` + column[i] + `" class="form-check-input" ` + checked + ` value="` + data[j].DATA + `" title="` + data[j].LABEL + `" ${disabled}>`;
          } else {
            html += `<input type="` + type[i] + `" id="` + id  + `" name="` + column[i] + `" data-col="` + column[i] + `" class="form-check-input" ` + checked + ` value="` + data[j].DATA + `" title="` + data[j].LABEL + `" onchange="` + changeCallback[i] + `(this);" ${disabled}>`;
          }
          html += `<label for="`+ id  + `" class="form-check-label"><span class="radio"></span>` +  data[j].LABEL + `</label>`;
          html += `</div>`;
        }
      }
      t.innerHTML = html;
    }
  });
}

