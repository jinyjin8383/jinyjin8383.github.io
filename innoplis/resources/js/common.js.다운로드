
function fnGetSaveObj() {
  const formId = arguments[0];
  const saveObj = new Object();
  [...document.querySelectorAll(`#${formId} input, textarea, select`)].map(elm => {
    var name = elm.name;
    var value = elm.value;
    const isDatePicker = elm?.classList?.contains('datepicker-input');

    if(isDatePicker) {
      value = replaceAll(elm.value, '-', '');
    } else if(elm.type === 'radio') {
      if(elm.checked) {
        value = elm.value;
      } else {
        value = saveObj[name];
      }
    } else if(elm.type === 'checkbox') {
      if(!elm.checked) {
        value = 'N';
      }
    }
    if(isEmpty(value)) value = '';
    if(isNotEmpty(name)) saveObj[name] = value;
  });
  return saveObj;
}

function fnGet(url, args, callback) {
  let urlName = '';
  if(isEmpty(arguments[3]) || arguments[3] == 'api') {
    urlName = environment.apiUrl;
  } else if(arguments[3] == 'dbrt') {
    urlName = environment.dbrtUrl;
  } else if(arguments[3] == 'site') {
    urlName = environment.siteUrl;
  } else if(arguments[3] == 'host') {
    urlName = environment.apiHost;
  }

  return new Promise((resolve, reject) => {
    const param = args ?? {};
    if(isNotEmpty(param)) {
      url += '?';
      Object.keys(param)
      .map((key, index, arr) => {
        url += key;
        url += '=';
        url += param[key];
        if(index < arr.length - 1) url += '&';
      });
    }

    const httpRequest = new XMLHttpRequest();
    httpRequest.onload = () => {
      if(httpRequest.readyState === XMLHttpRequest.DONE) {
        if(httpRequest.status === 200) {
          resolve(httpRequest);
        } else {
          reject(httpRequest);
        }
        if(isNotEmpty(callback)) callback(httpRequest);
      }
    };
    httpRequest.responseType = 'json';
    httpRequest.open('GET', urlName + url);
    httpRequest.send();
  }).catch((error)=> {
    return error;
  });
}

function fnPost(url, args, callback) {
