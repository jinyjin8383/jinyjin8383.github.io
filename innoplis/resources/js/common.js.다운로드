function fnExcelExport() {

  const title = arguments[0] + '.xlsx';
  const schema = arguments[1];
  const data = arguments[2];

  const resultData = new Array();

  // 헤더생성
  const headerData = new Array();
  for(let i=0; i<schema.length; i++) {
    const header = schema[i].header;
    headerData.push(header);
  }
  resultData.push(headerData);

  // 내용생성
  for(let i=0; i<data.length; i++) {
    const contentsData = new Array();
    for(let j=0; j<schema.length; j++) {
      const column = schema[j].column;
      const d = data[i][column];
      contentsData.push(d);
    }
    resultData.push(contentsData);
  }

  const wb = XLSX.utils.book_new();
  const newWorksheet = XLSX.utils.aoa_to_sheet(resultData);
  newWorksheet['!cols'] = fnFitToColumn(resultData);
  // newWorksheet['!autofilter'] = {ref : "A1:R11"};

  XLSX.utils.book_append_sheet(wb, newWorksheet, 'Sheet1');
  const wbout = XLSX.write(wb, {bookType:'xlsx',  type: 'binary'});
  saveAs(new Blob([s2ab(wbout)],{type:'application/octet-stream'}), title);
}

function fnFitToColumn() {
  const data = arguments[0];
  return data[0].map((a, i) => ({ wch: Math.max(...data.map(a2 => a2[i] ? a2[i].toString().length : 0)) + 5 }));
}

function s2ab(s) {
  var buf = new ArrayBuffer(s.length);
  var view = new Uint8Array(buf);
  for (var i=0; i<s.length; i++) view[i] = s.charCodeAt(i) & 0xFF;
  return buf;
}

function fnCreateRandomKey() {

  const array = new Uint32Array(3);
  self.crypto.getRandomValues(array);

  return array.join('');
}

function rPad(s, padLength, padString) {
  while(s.toString().length <= padLength) {
    s += padString;
  }
  return s.toString();
}

function collectionHas(all, elm) {
  for(var i = 0; i < all.length; i++) {
    if(all[i] == elm) return true;
  }
  return false;
}

function findParentBySelector(elm, selector) {
  const all = document.querySelectorAll(selector);
  var curr = elm.parentNode;
  while(curr && !collectionHas(all, curr)) {
    curr = curr.parentNode;
  }
  return curr;
}

function fnGetRowObj() {
