function fnDrawCol() {
  const elm = arguments[0];
  const rowIdx = arguments[1];
  const parent = elm.parentNode;

  if(elm.tagName === 'DIV') {
    [...elm.children].map(m => { fnDrawCol(m, rowIdx); });
  } else {
    var id = `${elm.id}_${rowIdx}`;

    if(elm.tagName === 'INPUT') {
      if(elm.name === 'DATA_STATUS') elm.value = 'C';

      var labelSiblings = [...parent.children].filter(f => f != elm && f.tagName === 'LABEL');
      labelSiblings.map(label => {
        if(elm.id === label.htmlFor) {
          label.htmlFor = id;
        }
      });

      if(elm.type === 'radio') {
        elm.name = `${elm.name}_${rowIdx}`;
      }
    }
    if(isNotEmpty(elm.id)) elm.id = id;
  }
}

function fnAddRow() {
  const addBtn = arguments[0];
  const btnWrap = findParentBySelector(addBtn, 'div');
  const table = btnWrap.nextElementSibling;
  const tbody = table.querySelector('tbody');
  const copyRow = tbody.querySelector('tr.hidden');
  const rowIdx = fnCreateRandomKey();

  var newRow = document.createElement('tr');

  [...copyRow.querySelectorAll('td')].map(td => {
    var newCol = td.cloneNode(true);
    [...newCol.children].map(child => {
      fnDrawCol(child, rowIdx);
    });
    newRow.appendChild(newCol);
  });
  tbody.appendChild(newRow);
}

function fnDeleteRow() {
  const delArr = arguments[0];
  const delBtn = arguments[1];
  const btnWrap = findParentBySelector(delBtn, 'div');
  const table = btnWrap.nextElementSibling;
  const tbody = table.querySelector('tbody');

